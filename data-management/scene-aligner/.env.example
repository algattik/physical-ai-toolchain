# Host directory containing one or more LeRobot-format datasets. Mounted
# read-only into both containers at /data/sample_datasets.
SCENE_ALIGNER_DATASETS_DIR=./sample_data

# Sub-path of the dataset whose video files the fake-camera dev tool
# replays. The aligner browses every dataset in the mount; this only
# configures the local debug publisher.
SCENE_ALIGNER_PUBLISH_DATASET=

# Default camera key the UI should preselect. Empty → first camera in the
# chosen dataset's info.json.
SCENE_ALIGNER_DEFAULT_CAMERA=

# Log verbosity for the aligner (DEBUG | INFO | WARNING | ERROR). DEBUG
# enables per-message diagnostics, decode failure details, publisher QoS on
# subscribe, and periodic "no frame received" heartbeats — useful when the
# live feed shows the placeholder/black frame against a real robot.
SCENE_ALIGNER_LOG_LEVEL=INFO

# Host port for the web UI.
SCENE_ALIGNER_PORT=8080

# Bind address for that port. 127.0.0.1 (default) means the UI is only
# reachable from this machine. Set to 0.0.0.0 to expose on the LAN — there
# is NO authentication, so anyone on the LAN can drive the UI and view the
# live camera. Use only on a trusted network.
SCENE_ALIGNER_BIND=127.0.0.1
